# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
# Get your connection string from https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/taskflow?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────
# Use a long, random string (min 32 chars) — never share this
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── Nodemailer (Gmail) ───────────────────────────────────
# Use an App Password, NOT your real Gmail password
# Guide: https://support.google.com/accounts/answer/185833
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_16_char_app_password

# ─── CORS ─────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173